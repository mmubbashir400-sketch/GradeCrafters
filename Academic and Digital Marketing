<script>
        // Micro-interaction for the map area
        document.querySelector('aside').addEventListener('mousemove', (e) => {
            const card = e.currentTarget.querySelector('.group');
            const rect = card.getBoundingClientRect();
            const x = e.clientX - rect.left;
            const y = e.clientY - rect.top;
            
            const centerX = rect.width / 2;
            const centerY = rect.height / 2;
            
            const rotateX = (y - centerY) / 25;
            const rotateY = (centerX - x) / 25;
            
            card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
        });

        document.querySelector('aside').addEventListener('mouseleave', (e) => {
            const card = e.currentTarget.querySelector('.group');
            card.style.transform = `perspective(1000px) rotateX(0deg) rotateY(0deg)`;
        });

        // Floating label behavior enhancement
        const inputs = document.querySelectorAll('input, textarea, select');
        inputs.forEach(input => {
            input.addEventListener('focus', () => {
                input.previousElementSibling.classList.add('text-secondary');
            });
            input.addEventListener('blur', () => {
                input.previousElementSibling.classList.remove('text-secondary');
            });
        });
    </script>
